# ── اجباری / Required ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── اختیاری / Optional ─────────────────────────────────────────────

# JSearch API (RapidAPI) — 200 req/month free
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Adzuna API — free tier available
# https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Google Sheets — save jobs to a spreadsheet
GSHEET_CREDENTIALS=
GSHEET_ID=

# Cloudflare Worker — custom scraper (advanced)
CF_WORKER_URL=

# شخصی‌سازی مهارت‌ها با کاما / Customize your skills (comma-separated)
# USER_SKILLS=wordpress,woocommerce,php,python,elementor

